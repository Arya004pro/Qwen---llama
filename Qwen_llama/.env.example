# Groq
GROQ_API_TOKEN=your_groq_api_token_here

# Models
QWEN_MODEL=qwen/qwen3-32b
LLAMA_MODEL=llama-3.3-70b-versatile
SQL_GENERATOR_MODEL=llama-3.3-70b-versatile
INSIGHTS_MODEL=qwen/qwen3-32b

# Reliability / token control
PARSE_INTENT_MAX_RETRIES=2
AI_INSIGHTS_MODE=adaptive
AI_INSIGHTS_ROW_THRESHOLD=8

# DuckDB
DUCKDB_PATH=motia/data/analytics.duckdb
